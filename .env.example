# ============================================================
# RecouvPro — Variables d'environnement
# Copier : cp .env.example .env
# NE JAMAIS committer .env sur GitHub
# ============================================================

# Base de données
DATABASE_URL=postgresql://user:password@host:5432/railway

# Serveur
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# JWT
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=COLLER_CLE_64_BYTES_ICI
JWT_REFRESH_SECRET=COLLER_AUTRE_CLE_64_BYTES_ICI

# PayDunya
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=

# Sentry
SENTRY_DSN=

# Cron
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=COLLER_CLE_32_BYTES_ICI
